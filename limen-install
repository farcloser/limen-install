#!/usr/bin/env bash
#
# dotaqua-bootstrap — set up / update a dev machine's global aqua toolchain.
# The global toolchain is ONE tool: the project scaffolder. Its config is
# embedded below — no separate config repo, no fetch.
#
# Per-project setup is separate: `aqua policy allow && aqua i -l` inside a repo.

set -euo pipefail

readonly AQUA_INSTALLER_VERSION="v4.0.2"
readonly AQUA_INSTALLER_SHA256="98b883756cdd0a6807a8c7623404bfc3bc169275ad9064dc23a6e24ad398f43d"

# Overridable for ONE reason: this is aqua's OWN env var. If aqua is already told
# where its global config lives, we must write the file there so aqua reads it.
# Exported once here so `aqua` (a child process) inherits it everywhere below.
export AQUA_GLOBAL_CONFIG="${AQUA_GLOBAL_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/aqua/aqua.yaml}"

# shellcheck disable=SC2016
readonly AQUA_BIN_EXPR='${AQUA_ROOT_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aquaproj-aqua}/bin'

SHELL_CHANGED=0   # set to 1 if we modify the shell rc (→ advise opening a new shell)

log() { printf '› %s\n' "$*"; }
ok()  { printf '✓ %s\n' "$*"; }
err() { printf '✗ %s\n' "$*" >&2; }

verify_sha256() {  # $1=file $2=expected ; shasum ships on macOS + mainstream Linux
  echo "$2  $1" | shasum -a 256 -c - >/dev/null 2>&1 \
    || { err "checksum mismatch: ${1##*/}"; exit 1; }
}

install_aqua() {
  command -v aqua >/dev/null 2>&1 && { ok "aqua present"; return; }
  log "installing aqua ${AQUA_INSTALLER_VERSION}"
  local t; t="$(mktemp -d)"
  curl -fsSL -o "$t/i" \
    "https://raw.githubusercontent.com/aquaproj/aqua-installer/${AQUA_INSTALLER_VERSION}/aqua-installer"
  verify_sha256 "$t/i" "$AQUA_INSTALLER_SHA256"
  chmod +x "$t/i"; "$t/i"; rm -rf "$t"
  eval "export PATH=\"$(eval echo "$AQUA_BIN_EXPR"):\$PATH\""
  ok "aqua installed"
}

ensure_shell_config() {
  local rc
  case "${SHELL##*/}" in
    zsh)  rc="$HOME/.zshrc" ;;
    bash) rc="$HOME/.bashrc" ;;
    *)    rc="$HOME/.profile" ;;
  esac
  if ! grep -qF 'aquaproj-aqua/bin' "$rc" 2>/dev/null; then
    # shellcheck disable=SC2016
    printf '\n# aqua\nexport PATH="%s:$PATH"\n' "$AQUA_BIN_EXPR" >> "$rc"
    SHELL_CHANGED=1
  fi
  if ! grep -qF 'AQUA_GLOBAL_CONFIG' "$rc" 2>/dev/null; then
    printf 'export AQUA_GLOBAL_CONFIG="%s"\n' "$AQUA_GLOBAL_CONFIG" >> "$rc"
    SHELL_CHANGED=1
  fi
  eval "export PATH=\"$(eval echo "$AQUA_BIN_EXPR"):\$PATH\""
}

# The entire global config, inlined. Bump the scaffolder version here.
write_config() {
  mkdir -p "$(dirname "$AQUA_GLOBAL_CONFIG")"
  cat > "$AQUA_GLOBAL_CONFIG" <<'YAML'
---
# Global aqua config — the project scaffolder, nothing else.
checksum:
  enabled: true
registries:
  - type: standard
    ref: v4.530.0 # renovate: depName=aquaproj/aqua-registry
packages:
  - name: farcloser/limen@v0.0.1 # renovate: depName=farcloser/limen
YAML
  ok "global config written: ${AQUA_GLOBAL_CONFIG}"
}

install_tools() {
  aqua i -a
  ok "scaffolder ready"
}

# One idempotent path — safe on a fresh machine AND as an update. Each step
# self-guards: aqua install skips if present, PATH/config appends skip if already
# there, the config is rewritten, and `aqua i -a` installs only what's missing.
install_aqua
ensure_shell_config
write_config
install_tools
if [ "$SHELL_CHANGED" = 1 ]; then
  ok "open a new shell to pick up PATH changes"
fi
ok "done"
