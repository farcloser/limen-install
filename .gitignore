# --- OS noise ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor / IDE ---
.idea/
.vscode/
*.swp
*~

# Scratch / work-in-progress files
*.local
_scratch/
WIP_*

# Build output and Go artifacts (subprojects keep their own .gitignore too)
/build

# =========================
#  Rust
# =========================
# Cargo build output
/target/
# Cargo.lock: COMMIT for binaries/apps, IGNORE for libraries.
# Uncomment the next line ONLY if this is a published library crate:
# Cargo.lock
# Backup files from `cargo fmt` / rustfmt edits
**/*.rs.bk
# MSVC debug info (Windows toolchain)
*.pdb

# =========================
#  Svelte / SvelteKit / Node
# =========================
# Dependencies
node_modules/
# SvelteKit build + generated types/runtime
.svelte-kit/
# Vite cache/output
.vite/
vite.config.*.timestamp-*
# Package manager debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- added by limen fix: baseline patterns ---
/tmp
